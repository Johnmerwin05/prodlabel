{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.32.1",
    "scripts": {
        "build": "vite build",
        "dev": "vite --host=127.0.0.1 --strictPort",
        "start": "concurrently -k -n laravel,queue,reverb,vite -c blue,green,magenta,cyan \"php artisan serve --host=127.0.0.1 --port=8000\" \"php artisan queue:work --queue=printing,default --tries=3\" \"php artisan reverb:start --host=127.0.0.1 --port=8080\" \"vite --host=127.0.0.1 --strictPort\"",
        "typecheck": "tsc --noEmit --pretty false"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.7",
        "@radix-ui/react-progress": "^1.1.7",
        "@radix-ui/react-slot": "^1.2.3",
        "@tanstack/react-query": "^5.90.12",
        "axios": "^1.11.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.4.0",
        "lucide-react": "^0.468.0",
        "next-themes": "^0.4.6",
        "radix-ui": "^1.5.0",
        "react": "^19.1.0",
        "react-day-picker": "^10.0.1",
        "react-dom": "^19.1.0",
        "react-hook-form": "^7.68.0",
        "react-router-dom": "^7.10.1",
        "recharts": "3.8.0",
        "shadcn": "^4.11.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.4.0",
        "tw-animate-css": "^1.4.0",
        "vaul": "^1.1.2",
        "zod": "^4.1.13",
        "zustand": "^5.0.8"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.3",
        "vite": "^7.0.7"
    }
}
